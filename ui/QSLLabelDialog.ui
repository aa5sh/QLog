       <!-- Tab 2: Content -->
       <widget class="QWidget" name="contentTab">
        <attribute name="title">
         <string>Content</string>
        </attribute>
        <layout class="QVBoxLayout" name="contentTabLayout">
         <!-- Label Content group -->
         <item>
          <widget class="QGroupBox" name="contentGroup">
           <property name="title">
            <string>Label Content</string>
           </property>
           <layout class="QVBoxLayout" name="contentVLayout">
            <!-- Grouping option first so it's prominent -->
            <item>
             <widget class="QCheckBox" name="groupQSOsCheck">
              <property name="text">
               <string>Group multiple QSOs by callsign (table layout)</string>
              </property>
              <property name="checked">
               <bool>true</bool>
              </property>
              <property name="toolTip">
               <string>When checked, all QSOs with the same callsign share one label printed as a table. When unchecked, one label per QSO.</string>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QFrame" name="contentSeparator">
              <property name="frameShape">
               <enum>QFrame::HLine</enum>
              </property>
              <property name="frameShadow">
               <enum>QFrame::Sunken</enum>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QCheckBox" name="showCallsignCheck">
              <property name="text">
               <string>Callsign (To Radio)</string>
              </property>
              <property name="checked">
               <bool>true</bool>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QCheckBox" name="showDateTimeCheck">
              <property name="text">
               <string>Date / Time (UTC)</string>
              </property>
              <property name="checked">
               <bool>true</bool>
