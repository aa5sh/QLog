            </item>
            <item>
             <widget class="QCheckBox" name="showRSTCheck">
              <property name="text">
               <string>RST Sent / Received</string>
              </property>
              <property name="checked">
               <bool>true</bool>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QCheckBox" name="showFreqCheck">
              <property name="text">
               <string>Frequency</string>
              </property>
              <property name="checked">
               <bool>false</bool>
