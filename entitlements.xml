<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" 
"http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow JIT for V8 engine -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Allow unsigned executable memory regions for V8 -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Allow loading of non-Apple-signed dynamic libraries (QtWebEngine needs this) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Sandbox should be disabled if you're not using sandboxing -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
